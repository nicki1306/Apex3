# ============================================
# .gitignore para Apex3 (FastAPI + Angular)
# ============================================

# ---------- Variables de entorno y secretos ----------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ---------- Python / Backend ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---------- Node / Angular / Frontend ----------
node_modules/
/dist/
/tmp/
/out-tsc/
/bazel-out/
.angular/cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Editores / IDEs ----------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Bases de datos locales ----------
*.sqlite
*.sqlite3
*.db

# ---------- Logs ----------
logs/
*.log

# ---------- Machine Learning (para cuando agregues ML) ----------
# Datasets grandes (usar DVC o similar para versionarlos)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Modelos entrenados (pesan mucho)
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
models/*.bin
models/*.safetensors

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Experimentos / outputs
mlruns/
wandb/
runs/